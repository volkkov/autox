<?xml version="1.0" encoding="utf-8"?>
<!--
  canRetrieveWindowContent: required to read the node tree.
  flagRetrieveInteractiveWindows: getWindows() returns every interactive window.
  flagReportViewIds: nodes carry their resource-id (the selector key).
  flagIncludeNotImportantViews: include all views, like uiautomator's uncompressed dump.
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeAllMask"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagDefault|flagRetrieveInteractiveWindows|flagReportViewIds|flagIncludeNotImportantViews"
    android:canPerformGestures="true"
    android:canRetrieveWindowContent="true"
    android:description="@string/accessibility_description"
    android:notificationTimeout="0" />
